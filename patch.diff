index dc31a4e8..3f9b2d41 100644
--- a/internal/agents/wb_api_agent/composer/helpers.go
+++ b/internal/agents/wb_api_agent/composer/helpers.go
@@ -115,4 +115,35 @@ func requestBodyRequired(schemaJSON string) bool {
 	required, _ := root["required"].(bool)
 	return required
 }
+
+func requestBodySchemaRefName(schemaJSON string) string {
+	var root map[string]any
+	if json.Unmarshal([]byte(schemaJSON), &root) != nil {
+		return ""
+	}
+
+	content, ok := root["content"].(map[string]any)
+	if !ok {
+		return ""
+	}
+
+	jsonContent, ok := content["application/json"].(map[string]any)
+	if !ok {
+		return ""
+	}
+
+	schema, ok := jsonContent["schema"].(map[string]any)
+	if !ok {
+		return ""
+	}
+
+	ref, ok := schema["$ref"].(string)
+	if !ok {
+		return ""
+	}
+
+	const prefix = "#/components/schemas/"
+	if !strings.HasPrefix(ref, prefix) {
+		return ""
+	}
+
+	return strings.TrimSpace(strings.TrimPrefix(ref, prefix))
+}
